{
  "name": "genflow",
  "private": true,
  "version": "0.1.0",
  "description": "Unified Electron app for generating demo websites",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron",
    "dev": "npm run build:preload && vite",
    "build": "npm run build:preload && tsc --noEmit && vite build",
    "preview": "vite preview",
    "package": "electron-builder --mac --dir",
    "dist": "electron-builder --mac"
  },
  "dependencies": {
    "express": "^4.21.0",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.3.0",
    "electron-builder": "^26.0.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
