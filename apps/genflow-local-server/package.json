{
  "name": "genflow-local-server",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "vite build && electron .",
    "start": "vite build && electron .",
    "pack": "vite build && electron-builder --mac --dir",
    "dist": "vite build && electron-builder --mac"
  },
  "build": {
    "appId": "se.siteflow.genflow",
    "productName": "Genflow Server",
    "mac": {
      "target": "dir",
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
